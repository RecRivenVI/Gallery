{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gallery.local/schemas/query-cursor-v1.json",
  "title": "Gallery Query Cursor Claims v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "queryFingerprint",
    "sortProtocolVersion",
    "rankProtocolVersion",
    "queryPublicationId",
    "authorizationScopeHash",
    "lastSortKey",
    "lastRankTier",
    "lastCanonicalWorkId",
    "issuedAt",
    "leaseId",
    "expiresAt"
  ],
  "properties": {
    "queryFingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "sortProtocolVersion": {"const": 1},
    "rankProtocolVersion": {"const": 1},
    "queryPublicationId": {"type": "string", "pattern": "^qpub_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "authorizationScopeHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "lastSortKey": {"type": "string", "minLength": 1, "maxLength": 8192},
    "lastRankTier": {"type": "integer", "minimum": 0, "maximum": 3},
    "lastCanonicalWorkId": {"type": "string", "pattern": "^wrk_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "issuedAt": {"type": "string", "format": "date-time"},
    "leaseId": {"type": "string", "minLength": 1, "maxLength": 128},
    "expiresAt": {"type": "string", "format": "date-time"}
  }
}
