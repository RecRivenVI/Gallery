{
  "name": "@gallery/web",
  "version": "0.1.0-pre-alpha",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "js-yaml": "4.3.0"
  },
  "scripts": {
    "dev": "vite",
    "generate": "npm run generate:api && npm run generate:icons",
    "generate:api": "openapi-typescript ../internal/contract/api/openapi.yaml -o src/api/schema.gen.ts",
    "generate:icons": "node scripts/generate-icons.mjs",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "build": "npm run generate && tsc -b --pretty false && vite build",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --project=chromium --grep @smoke"
  },
  "dependencies": {
    "@rjsf/core": "6.7.0",
    "@rjsf/validator-ajv8": "6.7.0",
    "@tanstack/react-query": "5.101.4",
    "openapi-fetch": "0.17.0",
    "react": "19.2.8",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.8",
    "react-router-dom": "7.18.1",
    "vite-plugin-pwa": "1.3.0",
    "workbox-window": "7.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "prettier": "3.9.6",
    "sharp": "0.35.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
